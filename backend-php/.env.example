# =============================================================
#  AetherCore-Web3 | /backend-php/.env.example
#  COPY this file to .env and fill in your real values.
#  NEVER commit the real .env file to version control.
# =============================================================

# ── Database ───────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=aethercore_db
DB_USER=your_mysql_username
DB_PASSWORD=your_mysql_password

# ── Webhook Security ───────────────────────────────────────────
# The signing secret from your Alchemy / Moralis webhook dashboard.
# Used to verify incoming event payloads via HMAC-SHA256.
WEBHOOK_SECRET=your_alchemy_or_moralis_webhook_signing_secret

# ── App ────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
