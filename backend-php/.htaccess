# AetherCore-Web3 | /backend-php/.htaccess
#
# Apache mod_rewrite rules — routes all requests through index.php.
# Requires: AllowOverride All in the Apache vhost config (set in Dockerfile).
#
# ROUTING LOGIC:
#   1. Serve real files/directories (images, assets) directly — no rewrite.
#   2. Route everything else through index.php for PHP-side dispatch.
#
# This enables clean URLs like /api/pilot/0xAbc... instead of /index.php?path=...

Options -Indexes

RewriteEngine On

# ── Security: block access to sensitive files ──────────────────
RewriteRule ^\.env$                - [F,L]
RewriteRule ^composer\.(json|lock)$ - [F,L]
RewriteRule ^database\.sql$       - [F,L]

# ── Pass real files and directories through untouched ──────────
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ── Route everything else to index.php ─────────────────────────
RewriteRule ^ index.php [L]
