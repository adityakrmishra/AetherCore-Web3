# =============================================================
#  AetherCore-Web3 | /blockchain/.env.example
#  COPY this file to .env and fill in your real values.
#  NEVER commit the real .env file to version control.
# =============================================================

# ── RPC Endpoints ─────────────────────────────────────────────
# Get your Alchemy key: https://dashboard.alchemy.com/
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# ── Deployer Wallet ────────────────────────────────────────────
# The private key of the wallet that will deploy the contracts.
# DO NOT include the 0x prefix here.
# In production, use a hardware wallet or Gnosis Safe signer.
DEPLOYER_PRIVATE_KEY=your_private_key_without_0x_prefix

# ── Etherscan Verification ─────────────────────────────────────
# Get your API key: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key

# ── Optional: Gas Reporting ────────────────────────────────────
# Set to "true" to enable gas cost table after each test run.
REPORT_GAS=false
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key
